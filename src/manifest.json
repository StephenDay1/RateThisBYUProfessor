{
    "name": "Rate this BYU professor",
    "description": "Integration of Rate My Professors into BYU's MyMAP.",
    "version": "1.1.1",
    "manifest_version": 3,
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "images/LogoLarge.png"
    },
    "icons": {
        "16": "images/Logo.png",
        "32": "images/Logo.png",
        "48": "images/Logo.png",
        "128": "images/Logo.png"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://www.ratemyprofessors.com/*"
    ],
    "web_accessible_resources": [
        {
            "resources": ["scripts/injected-styles.css"],
            "matches": ["https://commtech.byu.edu/*"]
        }
    ],
    "background": {
        "service_worker": "scripts/scrape.js"
    },
    "content_scripts": [
        {
            "js": [
                "scripts/get_rating.js"
            ],
            "matches": [
                "https://commtech.byu.edu/auth/mymap/*"
            ],
            "run_at": "document_end"
        }
    ]
}